--  ACQUIRE THE GAME'S OWN MODULES VIA REQUIRE
--  We walk PlayerScripts to find the utility root
-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local PlayerScripts   = LP:WaitForChild("PlayerScripts", 10)
local PlayerModule    = PlayerScripts and PlayerScripts:FindFirstChild("PlayerModule")
local UtilRoot        = PlayerScripts and PlayerScripts:FindFirstChild("Util")      -- common name
    or PlayerScripts and PlayerScripts:FindFirstChild("Utilities")
    or PlayerScripts and PlayerScripts:FindFirstChild("Utils")

-- Fallback: brute-search for a ModuleScript that has a "Character" child
-- (matches the second code block perfectly)
if not UtilRoot then
    for _, obj in ipairs(PlayerScripts:GetDescendants()) do
        if obj:IsA("ModuleScript") and obj:FindFirstChild("Character")
           and obj:FindFirstChild("Player") and obj:FindFirstChild("Game") then
            UtilRoot = obj
            break
        end
    end
end

