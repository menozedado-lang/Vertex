    if key == "GodMode"      then if enabled then startGodMode()      else stopGodMode()      end end
    if key == "SpeedHack"    then if enabled then startSpeedHack()    else stopSpeedHack()    end end
    if key == "VoidEnemies"  then if enabled then startVoidEnemies()  else stopVoidEnemies()  end end
    if key == "NoClip"       then if enabled then startNoClip()       else stopNoClip()       end end
    if key == "CameraLock"   then if enabled then startCameraLock()   else stopCameraLock()   end end
    if key == "AutoShoot"    then if enabled then startAutoShoot()    else stopAutoShoot()    end end
