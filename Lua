-- =====================
--   TOGGLE LOGIC
-- =====================
local function toggleCursor(state)
    Config.CursorEnabled = state

    -- Show hide elements
    CrosshairFrame.Visible = state
    MovePad.Visible = state
    ClickButton.Visible = state
    RClickButton.Visible = state

    -- Update button color
    TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
        BackgroundColor3 = state
            and Color3.fromRGB(0, 180, 80)
            or Color3.fromRGB(30, 30, 30)
    }):Play()

    -- Update stroke color
    UIStroke.Color = state
        and Color3.fromRGB(0, 255, 100)
        or Color3.fromRGB(255, 255, 255)

    -- Update status
    StatusLabel.Text = state and "ON" or "OFF"
    StatusLabel.TextColor3 = state
        and Color3.fromRGB(0, 255, 100)
        or Color3.fromRGB(255, 80, 80)

    -- Reset cursor to center
    if state then
        CursorX = Camera.ViewportSize.X / 2
        CursorY = Camera.ViewportSize.Y / 2
        CrosshairFrame.Position = UDim2.new(
            0, CursorX - Config.CursorSize,
            0, CursorY - Config.CursorSize
        )
    end
end

ToggleButton.MouseButton1Click:Connect(function()
    toggleCursor(not Config.CursorEnabled)
end)

