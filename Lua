--  rawset into every item/weapon table we can find
local function patchWeaponTables()
    safePcall(function()
        -- try common paths the game's Item/Weapon module might use
        local paths = {
            {"ReplicatedStorage", "Modules", "ItemLibrary"},
            {"ReplicatedStorage", "Modules", "WeaponLibrary"},
            {"ReplicatedStorage", "Shared",  "Items"},
            {"ReplicatedStorage", "Data",    "Weapons"},
        }
        for _, pathArr in ipairs(paths) do
            local cur = game
            for _, seg in ipairs(pathArr) do
                cur = cur:FindFirstChild(seg)
                if not cur then break end
            end
            if cur and cur:IsA("ModuleScript") then
                local lib = safeRequire(cur)
                if type(lib) == "table" then
                    dumpModule(table.concat(pathArr, "."), lib)
                    -- rawset fire-rate / reload on every sub-table
                    for _, item in pairs(lib) do
                        if type(item) == "table" then
                            for _, key in ipairs({
                                "ReloadLength","ReloadTime","FireRate",
                                "Ammo","MaxAmmo","Magazine","MaxMagazine",
                                "CoolDown","Cooldown","Delay",
                            }) do
                                if item[key] ~= nil then
                                    State.originalValues[tostring(item.Name or "?") .. "_" .. key] = item[key]
                                    if State.NoReload then
                                        rawset(item, key, key:find("Ammo") and 9999 or 0)
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end

        -- Also patch via the Util modules we already required
        if UtilCommon then
            rawset(UtilCommon, "ReloadTime",  0)
            rawset(UtilCommon, "FireRate",     0.001)
            rawset(UtilCommon, "MaxAmmo",      9999)
            rawset(UtilCommon, "Ammo",         9999)
        end
    end)
end

