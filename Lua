local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local Library = {
    MainColor = Color3.fromRGB(20, 20, 20),
    AccentColor = Color3.fromRGB(0, 85, 255),
    BackgroundColor = Color3.fromRGB(15, 15, 15),
    TextColor = Color3.fromRGB(255, 255, 255),
    OutlineColor = Color3.fromRGB(40, 40, 40),
    Font = Enum.Font.Code,
}

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "VertexLibrary"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = CoreGui

local function CreateSharpFrame(parent, size, pos, color, outline)
    local frame = Instance.new("Frame")
    frame.Size = size
    frame.Position = pos
    frame.BackgroundColor3 = color
    frame.BorderSizePixel = outline and 1 or 0
    if outline then frame.BorderColor3 = Library.OutlineColor end
    frame.Parent = parent
    return frame
end

function Library:CreateWindow(title)
    local MainFrame = CreateSharpFrame(ScreenGui, UDim2.fromOffset(580, 380), UDim2.new(0.5, -290, 0.5, -190), self.BackgroundColor, true)
    local Sidebar = CreateSharpFrame(MainFrame, UDim2.new(0, 120, 1, 0), UDim2.new(0, 0, 0, 0), self.MainColor, true)
    
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 40)
    Title.BackgroundTransparency = 1
    Title.Text = title
    Title.TextColor3 = self.AccentColor
    Title.Font = self.Font
    Title.TextSize = 14
    Title.Parent = Sidebar

    local SidebarContainer = Instance.new("Frame")
    SidebarContainer.Size = UDim2.new(1, 0, 1, -40)
    SidebarContainer.Position = UDim2.new(0, 0, 0, 40)
    SidebarContainer.BackgroundTransparency = 1
    SidebarContainer.Parent = Sidebar
    Instance.new("UIListLayout", SidebarContainer).Padding = UDim.new(0, 2)

    local ContentArea = Instance.new("Frame")
    ContentArea.Size = UDim2.new(1, -120, 1, 0)
    ContentArea.Position = UDim2.new(0, 120, 0, 0)
    ContentArea.BackgroundTransparency = 1
    ContentArea.Parent = MainFrame

    local WindowObj = { MainTabs = {} }

    function WindowObj:CreateMainTab(name)
        local MainTabButton = Instance.new("TextButton")
        MainTabButton.Size = UDim2.new(1, 0, 0, 35)
        MainTabButton.BackgroundColor3 = Library.MainColor
        MainTabButton.Text = name
        MainTabButton.TextColor3 = Library.TextColor
        MainTabButton.Font = Library.Font
        MainTabButton.Parent = SidebarContainer
        
        local MainTabFrame = Instance.new("Frame")
        MainTabFrame.Size = UDim2.new(1, 0, 1, 0)
        MainTabFrame.BackgroundTransparency = 1
        MainTabFrame.Visible = false
        MainTabFrame.Parent = ContentArea
        
        local SubTabBar = CreateSharpFrame(MainTabFrame, UDim2.new(1, 0, 0, 30), UDim2.new(0, 0, 0, 0), Library.MainColor, true)
        Instance.new("UIListLayout", SubTabBar).FillDirection = Enum.FillDirection.Horizontal
        
        local SubContentArea = Instance.new("Frame")
        SubContentArea.Size = UDim2.new(1, 0, 1, -30)
        SubContentArea.Position = UDim2.new(0, 0, 0, 30)
        SubContentArea.BackgroundTransparency = 1
        SubContentArea.Parent = MainTabFrame

        local MainTabObj = { SubTabs = {} }

        MainTabButton.MouseButton1Click:Connect(function()
            for _, t in pairs(WindowObj.MainTabs) do t.Frame.Visible = false t.Button.TextColor3 = Library.TextColor end
            MainTabFrame.Visible = true
            MainTabButton.TextColor3 = Library.AccentColor
        end)

        function MainTabObj:CreateSubTab(subName)
            local SubButton = Instance.new("TextButton")
            SubButton.Size = UDim2.new(0, 90, 1, 0)
            SubButton.BackgroundColor3 = Library.MainColor
            SubButton.Text = subName
            SubButton.TextColor3 = Library.TextColor
            SubButton.Font = Library.Font
            SubButton.Parent = SubTabBar
            
            local SubFrame = Instance.new("Frame")
            SubFrame.Size = UDim2.new(1, 0, 1, 0)
            SubFrame.BackgroundTransparency = 1
            SubFrame.Visible = false
            SubFrame.Parent = SubContentArea
            
            local Left = Instance.new("ScrollingFrame")
            Left.Size = UDim2.new(0.5, -10, 1, -10)
            Left.Position = UDim2.new(0, 5, 0, 5)
            Left.BackgroundTransparency = 1
            Left.ScrollBarThickness = 0
            Left.Parent = SubFrame
            
            local Right = Instance.new("ScrollingFrame")
            Right.Size = UDim2.new(0.5, -10, 1, -10)
            Right.Position = UDim2.new(0.5, 5, 0, 5)
            Right.BackgroundTransparency = 1
            Right.ScrollBarThickness = 0
            Right.Parent = SubFrame

            Instance.new("UIListLayout", Left).Padding = UDim.new(0, 10)
            Instance.new("UIListLayout", Right).Padding = UDim.new(0, 10)

            SubButton.MouseButton1Click:Connect(function()
                for _, st in pairs(MainTabObj.SubTabs) do st.Frame.Visible = false st.Button.TextColor3 = Library.TextColor end
                SubFrame.Visible = true
                SubButton.TextColor3 = Library.AccentColor
            end)

            local SubTabObj = { Frame = SubFrame, Button = SubButton, Left = Left, Right = Right }
            table.insert(MainTabObj.SubTabs, SubTabObj)
            
            function SubTabObj:CreateGroupbox(gName, side)
                local parent = (side == "Right") and self.Right or self.Left
                local Group = CreateSharpFrame(parent, UDim2.new(1, 0, 0, 30), UDim2.new(0, 0, 0, 0), Library.BackgroundColor, true)
                Group.AutomaticSize = Enum.AutomaticSize.Y
                CreateSharpFrame(Group, UDim2.new(1, 0, 0, 1), UDim2.new(0, 0, 0, 0), Library.AccentColor)
                
                local GTitle = Instance.new("TextLabel")
                GTitle.Size = UDim2.new(1, 0, 0, 20)
                GTitle.BackgroundTransparency = 1
                GTitle.Text = gName
                GTitle.TextColor3 = Library.TextColor
                GTitle.Font = Library.Font
                GTitle.TextSize = 13
                GTitle.Parent = Group
                
                local Container = Instance.new("Frame")
                Container.Size = UDim2.new(1, -10, 0, 0)
                Container.Position = UDim2.new(0, 5, 0, 25)
                Container.BackgroundTransparency = 1
                Container.AutomaticSize = Enum.AutomaticSize.Y
                Container.Parent = Group
                Instance.new("UIListLayout", Container).Padding = UDim.new(0, 5)

                local GroupObj = {}

                function GroupObj:CreateToggle(text, default, callback)
                    local Toggle = Instance.new("TextButton")
                    Toggle.Size = UDim2.new(1, 0, 0, 20)
                    Toggle.BackgroundTransparency = 1
                    Toggle.Text = ""
                    Toggle.Parent = Container
                    
                    local Box = CreateSharpFrame(Toggle, UDim2.fromOffset(12, 12), UDim2.new(0, 0, 0.5, -6), Library.MainColor, true)
                    local Fill = CreateSharpFrame(Box, UDim2.new(1, -2, 1, -2), UDim2.new(0, 1, 0, 1), Library.AccentColor)
                    Fill.Visible = default
                    
                    local Label = Instance.new("TextLabel")
                    Label.Size = UDim2.new(1, -20, 1, 0)
                    Label.Position = UDim2.new(0, 20, 0, 0)
                    Label.BackgroundTransparency = 1
                    Label.Text = text
                    Label.TextColor3 = Library.TextColor
                    Label.Font = Library.Font
                    Label.TextSize = 13
                    Label.TextXAlignment = Enum.TextXAlignment.Left
                    Label.Parent = Toggle
                    
                    Toggle.MouseButton1Click:Connect(function()
                        default = not default
                        Fill.Visible = default
                        callback(default)
                    end)
                end

                return GroupObj
            end
            return SubTabObj
        end
        
        table.insert(WindowObj.MainTabs, { Frame = MainTabFrame, Button = MainTabButton })
        return MainTabObj
    end
    return WindowObj
end

return Library
