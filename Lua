-- в”Җв”Җ AUTO SHOOT в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function startAutoShoot()
    State.autoShootConn = RunService.Heartbeat:Connect(function()
        safePcall(function()
            if not State.CameraLock then return end
            local target = getNearestEnemy()
            if not target then return end
            local chr  = LP.Character
            local tool = chr and chr:FindFirstChildOfClass("Tool")
            if not tool then return end
            tool:Activate()
            for _, v in ipairs(tool:GetDescendants()) do
                if v:IsA("RemoteEvent") then
                    local nl = v.Name:lower()
                    if nl:find("shoot") or nl:find("fire") or nl:find("attack") then
                        safePcall(function() v:FireServer() end)
                    end
                end
            end
        end)
    end)
end

local function stopAutoShoot()
    if State.autoShootConn then
        State.autoShootConn:Disconnect()
        State.autoShootConn = nil
    end
end

-- в”Җв”Җ RAYCAST HOOK в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  Hooks Util.Raycast cast function to redirect missed shots
--  Only applied when CameraLock is ON
local function applyRaycastHook()
    if not UtilRaycast then return end
    safePcall(function()
        for k, v in pairs(UtilRaycast) do
            if type(v) == "function" then
                local kl = k:lower()
                if kl:find("cast") or kl:find("shoot") or kl:find("fire") then
                    hookModFn(UtilRaycast, k, function(...)
                        local orig   = State.hookedFunctions[k]
                        local result = orig(...)
                        -- only fabricate if camera lock is on and real cast missed
                        if State.CameraLock and (not result or not result.Instance) then
                            local target = getNearestEnemy()
                            if target then
                                local head = target.Character and
                                             target.Character:FindFirstChild("Head")
                                if head then
                                    return {
                                        Instance = head,
                                        Position = head.Position,
                                        Normal   = Vector3.new(0, 1, 0),
                                        Material = Enum.Material.SmoothPlastic,
                                    }
                                end
                            end
                        end
                        return result
                    end)
                    print("[exploit] Raycast hook applied on: " .. k)
                    break
                end
            end
        end
    end)
end

applyRaycastHook()

-- в”Җв”Җ TEAM HOOK в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  Only applied once, does not block any game flow
local function applyTeamHook()
    if not UtilTeam then return end
    safePcall(function()
        hookModFn(UtilTeam, "IsEnemy", function(p1, p2, ...)
            if p1 == LP or p2 == LP then return false end
            return State.hookedFunctions["IsEnemy"](p1, p2, ...)
        end)
        hookModFn(UtilTeam, "IsFriendly", function(p1, p2, ...)
            if p1 == LP or p2 == LP then return true end
            return State.hookedFunctions["IsFriendly"](p1, p2, ...)
        end)
    end)
end

applyTeamHook()

-- в”Җв”Җ FEATURE DISPATCH в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function applyFeature(key, value)
    if key == "GodMode" then
        if value then startGodMode()   else stopGodMode()   end

    elseif key == "SpeedHack" then
        if value then startSpeedHack() else stopSpeedHack() end

    elseif key == "NoClip" then
        if value then startNoClip()    else stopNoClip()    end

    elseif key == "VoidEnemies" then
        if value then startVoidEnemies() else stopVoidEnemies() end

    elseif key == "CameraLock" then
        if value then startCameraLock() else stopCameraLock() end

    elseif key == "AutoShoot" then
        if value then startAutoShoot()  else stopAutoShoot()  end

    elseif key == "InfiniteAmmo" or key == "NoReload" then
        if value then patchWeaponTables() end

    elseif key == "RemoteSpy" then
        spyLog = {}  -- reset log on toggle
        print("[exploit] Remote Spy " .. (value and "ON" or "OFF"))

    elseif key == "AntiAC" then
        print("[exploit] AntiAC __index lie " .. (value and "ON" or "OFF"))

    elseif key == "SpeedMultiplier" then
        -- value is the new number from the slider
        -- speedConn will pick it up next Heartbeat automatically
        if not State.SpeedHack then return end

    elseif key == "AimFOV" then
        -- picked up automatically by getNearestEnemy()
    end
end

