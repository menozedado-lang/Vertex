-- в”Җв”Җ INFINITE AMMO / NO RELOAD в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
--  rawset into every weapon/item library table we can find.
--  Does NOT touch remotes at all.
local function patchWeaponTables()
    safePcall(function()
        -- common module paths to try
        local candidates = {}
        for _, obj in ipairs(ReplicatedStorage:GetDescendants()) do
            if obj:IsA("ModuleScript") then
                local nl = obj.Name:lower()
                if nl:find("item") or nl:find("weapon")
                   or nl:find("gun") or nl:find("loadout") then
                    table.insert(candidates, obj)
                end
            end
        end
        for _, obj in ipairs(PlayerScripts:GetDescendants()) do
            if obj:IsA("ModuleScript") then
                local nl = obj.Name:lower()
                if nl:find("item") or nl:find("weapon")
                   or nl:find("gun") or nl:find("loadout") then
                    table.insert(candidates, obj)
                end
            end
        end

        for _, mod in ipairs(candidates) do
            local lib = safeRequire(mod)
            if type(lib) == "table" then
                print("[exploit] patching: " .. mod:GetFullName())
                local function patchTable(t, depth)
                    if depth > 4 then return end
                    for _, item in pairs(t) do
                        if type(item) == "table" then
                            local targets = {
                                ReloadLength  = State.NoReload    and 0    or nil,
                                ReloadTime    = State.NoReload    and 0    or nil,
                                FireRate      = State.NoReload    and 0.001 or nil,
                                CoolDown      = State.NoReload    and 0    or nil,
                                Cooldown      = State.NoReload    and 0    or nil,
                                Delay         = State.NoReload    and 0    or nil,
                                Ammo          = State.InfiniteAmmo and 9999 or nil,
                                MaxAmmo       = State.InfiniteAmmo and 9999 or nil,
                                Magazine      = State.InfiniteAmmo and 9999 or nil,
                                MaxMagazine   = State.InfiniteAmmo and 9999 or nil,
                                StoredAmmo    = State.InfiniteAmmo and 9999 or nil,
                            }
                            for k, v in pairs(targets) do
                                if item[k] ~= nil and v ~= nil then
                                    if not State.originalValues[tostring(item.Name or "?").."_"..k] then
                                        State.originalValues[tostring(item.Name or "?").."_"..k] = item[k]
                                    end
                                    rawset(item, k, v)
                                    print(string.format("  [rawset] %s.%s = %s",
                                        tostring(item.Name or "?"), k, tostring(v)))
                                end
                            end
                            patchTable(item, depth + 1)
                        end
                    end
                end
                patchTable(lib, 0)
            end
        end

        -- also patch directly via Util modules
        local utilTargets = {UtilCommon, UtilCharacter}
        for _, ut in ipairs(utilTargets) do
            if ut then
                if State.NoReload then
                    rawset(ut, "ReloadTime",   0)
                    rawset(ut, "ReloadLength",  0)
                    rawset(ut, "FireRate",       0.001)
                    rawset(ut, "Cooldown",       0)
                end
                if State.InfiniteAmmo then
                    rawset(ut, "MaxAmmo",  9999)
                    rawset(ut, "Ammo",     9999)
                    rawset(ut, "Magazine", 9999)
                end
            end
        end
    end)
end

