    ic.Position         = UDim2.fromOffset(12, 13)
    ic.BackgroundColor3 = cfg.iconColor or PAL.accent
    ic.BorderSizePixel  = 0
    ic.Parent           = card
    mkCorner(ic, 12)

    local icLbl = Instance.new("TextLabel")
    icLbl.Size               = UDim2.fromScale(1, 1)
    icLbl.BackgroundTransparency = 1
    icLbl.Text               = cfg.icon
    icLbl.TextColor3         = Color3.new(1, 1, 1)
    icLbl.Font               = Enum.Font.GothamBold
    icLbl.TextSize           = 20
    icLbl.Parent             = ic

    -- title
    local tLbl = Instance.new("TextLabel")
    tLbl.Size               = UDim2.new(1, -130, 0, 20)
    tLbl.Position           = UDim2.fromOffset(66, 14)
    tLbl.BackgroundTransparency = 1
    tLbl.Text               = cfg.title
    tLbl.TextColor3         = PAL.text
    tLbl.Font               = Enum.Font.GothamBold
    tLbl.TextSize           = 14
    tLbl.TextXAlignment     = Enum.TextXAlignment.Left
    tLbl.Parent             = card

    -- subtitle
    local sLbl = Instance.new("TextLabel")
    sLbl.Size               = UDim2.new(1, -130, 0, 16)
    sLbl.Position           = UDim2.fromOffset(66, 36)
    sLbl.BackgroundTransparency = 1
    sLbl.Text               = cfg.sub
    sLbl.TextColor3         = PAL.sub
    sLbl.Font               = Enum.Font.Gotham
    sLbl.TextSize           = 10
    sLbl.TextXAlignment     = Enum.TextXAlignment.Left
    sLbl.TextWrapped        = true
    sLbl.Parent             = card

    -- pill
    local pill = Instance.new("Frame")
    pill.Size             = UDim2.fromOffset(62, 28)
    pill.Position         = UDim2.new(1, -74, 0.5, -14)
    pill.BackgroundColor3 = State[cfg.stateKey] and onCol or PAL.off
    pill.BorderSizePixel  = 0
    pill.Parent           = card
    mkCorner(pill, 14)

    local pillTxt = Instance.new("TextLabel")
    pillTxt.Size               = UDim2.fromScale(1, 1)
    pillTxt.BackgroundTransparency = 1
    pillTxt.Text               = State[cfg.stateKey] and "ON" or "OFF"
    pillTxt.TextColor3         = Color3.new(1, 1, 1)
    pillTxt.Font               = Enum.Font.GothamBold
    pillTxt.TextSize           = 12
    pillTxt.Parent             = pill

    local knob = Instance.new("Frame")
    knob.Size             = UDim2.fromOffset(20, 20)
    knob.Position         = State[cfg.stateKey]
        and UDim2.fromOffset(38, 4) or UDim2.fromOffset(4, 4)
    knob.BackgroundColor3 = Color3.new(1, 1, 1)
    knob.BorderSizePixel  = 0
    knob.Parent           = pill
    mkCorner(knob, 10)

    -- invisible hit target
    local hit = Instance.new("TextButton")
    hit.Size               = UDim2.fromScale(1, 1)
    hit.BackgroundTransparency = 1
    hit.Text               = ""
    hit.ZIndex             = 5
    hit.Parent             = card

    local function refresh()
        local on = State[cfg.stateKey]
        tw(pill,  {BackgroundColor3 = on and onCol or PAL.off}, 0.15)
        tw(knob,  {Position = on
            and UDim2.fromOffset(38, 4)
            or  UDim2.fromOffset( 4, 4)}, 0.15)
        pillTxt.Text = on and "ON" or "OFF"
    end

    hit.MouseButton1Click:Connect(function()
        State[cfg.stateKey] = not State[cfg.stateKey]
        refresh()
        applyFeature(cfg.stateKey, State[cfg.stateKey])
        -- icon pulse
        tw(ic, {BackgroundColor3 = PAL.accentHi}, 0.07)
        task.delay(0.13, function()
            tw(ic, {BackgroundColor3 = cfg.iconColor or PAL.accent}, 0.13)
        end)
        -- border flash
        tw(cStroke, {Color = State[cfg.stateKey] and onCol or PAL.accent}, 0.1)
        task.delay(0.5, function()
            tw(cStroke, {Color = PAL.accent}, 0.35)
        end)
    end)

    hit.MouseEnter:Connect(function()
        tw(card, {BackgroundColor3 = Color3.fromRGB(30, 22, 60)}, 0.1)
    end)
    hit.MouseLeave:Connect(function()
        tw(card, {BackgroundColor3 = PAL.panel}, 0.1)
    end)
end

-- в”Җв”Җ slider card factory в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function makeSlider(cfg)
    local card = Instance.new("Frame")
    card.LayoutOrder      = cfg.order
    card.Size             = UDim2.new(1, 0, 0, 70)
    card.BackgroundColor3 = PAL.panel
    card.BorderSizePixel  = 0
    card.Parent           = Scroll
    mkCorner(card, 14)
    mkStroke(card, PAL.accent, 1.5)

    local valLbl = Instance.new("TextLabel")
    valLbl.Size               = UDim2.new(1, -20, 0, 20)
    valLbl.Position           = UDim2.fromOffset(14, 10)
    valLbl.BackgroundTransparency = 1
    valLbl.Text               = cfg.title .. ":  "
        .. tostring(State[cfg.stateKey]) .. (cfg.suffix or "")
    valLbl.TextColor3         = PAL.text
    valLbl.Font               = Enum.Font.GothamBold
    valLbl.TextSize           = 13
    valLbl.TextXAlignment     = Enum.TextXAlignment.Left
    valLbl.Parent             = card

    local trackBg = Instance.new("Frame")
    trackBg.Size             = UDim2.new(1, -28, 0, 10)
    trackBg.Position         = UDim2.fromOffset(14, 40)
    trackBg.BackgroundColor3 = PAL.off
    trackBg.BorderSizePixel  = 0
    trackBg.Parent           = card
    mkCorner(trackBg, 5)

    local pct  = (State[cfg.stateKey] - cfg.min) / (cfg.max - cfg.min)
    local fill = Instance.new("Frame")
    fill.Size             = UDim2.fromScale(math.clamp(pct, 0, 1), 1)
    fill.BackgroundColor3 = cfg.fillColor or PAL.accent
    fill.BorderSizePixel  = 0
    fill.Parent           = trackBg
    mkCorner(fill, 5)

    local dragging = false

    local function updateVal(inputX)
        local rel = math.clamp(
            (inputX - trackBg.AbsolutePosition.X) / trackBg.AbsoluteSize.X,
            0, 1
        )
        local val = math.floor(cfg.min + rel * (cfg.max - cfg.min))
        State[cfg.stateKey] = val
        tw(fill, {Size = UDim2.fromScale(rel, 1)}, 0.04)
        valLbl.Text = cfg.title .. ":  " .. tostring(val) .. (cfg.suffix or "")
        applyFeature(cfg.stateKey, val)
    end

    local hitArea = Instance.new("TextButton")
    hitArea.Size               = UDim2.new(1, 0, 1, 20)
    hitArea.Position           = UDim2.fromOffset(0, -10)
    hitArea.BackgroundTransparency = 1
    hitArea.Text               = ""
    hitArea.ZIndex             = 5
    hitArea.Parent             = trackBg

    hitArea.MouseButton1Down:Connect(function(x, _) dragging=true updateVal(x) end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            updateVal(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

