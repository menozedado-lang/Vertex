local Camera = workspace.CurrentCamera

local function getLpRoot()
    local chr = LP.Character
    return chr and chr:FindFirstChild("HumanoidRootPart")
end

local function getLpHum()
    local chr = LP.Character
    return chr and chr:FindFirstChildOfClass("Humanoid")
end

local function getNearestEnemy()
    local cam    = Camera
    local vp     = cam.ViewportSize
    local center = Vector2.new(vp.X / 2, vp.Y / 2)
    local best, bestDist = nil, math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            local pChr = p.Character
            local head = pChr and pChr:FindFirstChild("Head")
            local phum = pChr and pChr:FindFirstChildOfClass("Humanoid")
            if head and phum and phum.Health > 0 then
                local sp, onScreen = cam:WorldToScreenPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                    if dist < State.AimFOV and dist < bestDist then
                        bestDist = dist
                        best     = p
                    end
                end
            end
        end
    end
    return best
end

