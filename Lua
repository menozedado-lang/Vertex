--  METATABLE HOOK
--  KEY FIX: the old version blocked damage/reload remotes
--  unconditionally. Now NOTHING is blocked unless the specific
--  toggle is ON, and we use a whitelist approach вҖ” only known
--  bad patterns are touched. Everything else passes through.
-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local mt    = getrawmetatable(game)
local oldNC = mt.__namecall
local oldNI = mt.__index
setreadonly(mt, false)

-- remote spy log (only prints when State.RemoteSpy = true)
local spyLog = {}

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args   = {...}

    -- в”Җв”Җ Remote Spy (opt-in, off by default) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    if State.RemoteSpy then
        if method == "FireServer" or method == "InvokeServer"
           or method == "FireAllClients" then
            local path = self:GetFullName()
            if not spyLog[path] then
                spyLog[path] = true
                print(string.format("[SPY] %s :: %s", path, method))
                for i, a in ipairs(args) do
                    print(string.format("  arg[%d] = %s (%s)", i, tostring(a), type(a)))
                end
            end
        end
    end

    --[[
        IMPORTANT: we do NOT block any remotes here anymore.
        The old code blocked "damage","hurt","kill","reload","ammo"
        which also caught matchmaking, lobby, queue and UI remotes
        that contained those words in their name.

        Blocking is done per-feature ONLY when:
          - The feature is ON
          - We are 100% sure the remote is a damage/hit confirmation
            sent FROM server TO client (which cannot be blocked anyway)
            or a client-to-server hit report we want to suppress.

        For now the hook is purely a spy + future hook point.
        Features work via Heartbeat loops and rawset, not remote blocking.
    ]]

    return oldNC(self, ...)
end)

-- __index hook: only lies when AntiAC is ON
-- and only about the exact properties the AC reads
mt.__index = newcclosure(function(self, key)
    if State.AntiAC then
        local chr = LP.Character
        if chr then
            local hum = chr:FindFirstChildOfClass("Humanoid")
            if hum and self == hum then
                -- lie to anti-cheat property polls
                if key == "WalkSpeed" then return 16 end
                if key == "JumpPower" then return 50 end
            end
        end
    end
    return oldNI(self, key)
end)

setreadonly(mt, true)

