-- =====================
--    DRAG BUTTON
-- =====================
local dragging = false
local dragOffsetX = 0
local dragOffsetY = 0

ToggleButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragOffsetX = input.Position.X - ToggleButton.AbsolutePosition.X
        dragOffsetY = input.Position.Y - ToggleButton.AbsolutePosition.Y
    end
end)

ToggleButton.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.Touch then
        local newX = input.Position.X - dragOffsetX
        local newY = input.Position.Y - dragOffsetY
        ToggleButton.Position = UDim2.new(0, newX, 0, newY)
        StatusLabel.Position = UDim2.new(0, newX, 0, newY + 57)
    end
end)

ToggleButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

