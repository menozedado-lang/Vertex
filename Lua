-- в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
local function hookModFn(tbl, key, replacement)
    if not tbl or type(tbl[key]) ~= "function" then return false end
    local ok, err = pcall(function()
        State.hookedFunctions[key] = hookfunction(tbl[key], replacement)
    end)
    if ok then
        print("[exploit] hooked fn: " .. key)
        return true
    end
    warn("[exploit] hookfunction failed (" .. key .. "): " .. tostring(err))
    return false
end

