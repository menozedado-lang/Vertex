-- ‚ĒÄ‚ĒÄ slider factory ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local function makeSlider(cfg)
    --[[
    cfg = {
        order   = int,
        title   = "string",
        min     = number,
        max     = number,
        default = number,
        suffix  = "string",
        stateKey= "string",   -- key in State (must be a number)
        iconColor = Color3,
    }
    ]]
    local card = Instance.new("Frame")
    card.LayoutOrder      = cfg.order
    card.Size             = UDim2.new(1,0,0,72)
    card.BackgroundColor3 = PAL.panel
    card.BorderSizePixel  = 0
    card.Parent           = Scroll
    corner(card, 14)
    uiStroke(card, PAL.accent, 1.5)

    local valLbl = Instance.new("TextLabel")
    valLbl.Size               = UDim2.new(1,-20,0,20)
    valLbl.Position           = UDim2.fromOffset(12,8)
    valLbl.BackgroundTransparency = 1
    valLbl.Text               = cfg.title .. ":  " .. tostring(State[cfg.stateKey]) .. (cfg.suffix or "")
    valLbl.TextColor3         = PAL.text
    valLbl.Font               = Enum.Font.GothamBold
    valLbl.TextSize           = 13
    valLbl.TextXAlignment     = Enum.TextXAlignment.Left
    valLbl.Parent             = card

    local track = Instance.new("Frame")
    track.Size             = UDim2.new(1,-24,0,10)
    track.Position         = UDim2.fromOffset(12,38)
    track.BackgroundColor3 = PAL.off
    track.BorderSizePixel  = 0
    track.Parent           = card
    corner(track, 5)

    local fill = Instance.new("Frame")
    local pct  = (State[cfg.stateKey] - cfg.min) / (cfg.max - cfg.min)
    fill.Size             = UDim2.fromScale(math.clamp(pct,0,1), 1)
    fill.BackgroundColor3 = cfg.iconColor or PAL.accent
    fill.BorderSizePixel  = 0
    fill.Parent           = track
    corner(fill, 5)

    -- drag
    local dragging = false
    local function updateSlider(inputX)
        local tPos   = track.AbsolutePosition.X
        local tSize  = track.AbsoluteSize.X
        local rel    = math.clamp((inputX - tPos) / tSize, 0, 1)
        local val    = math.floor(cfg.min + rel * (cfg.max - cfg.min))
        State[cfg.stateKey] = val
        tween(fill, {Size = UDim2.fromScale(rel,1)}, 0.05)
        valLbl.Text = cfg.title .. ":  " .. tostring(val) .. (cfg.suffix or "")
        applyFeature(cfg.stateKey, val)
    end

    local hitArea = Instance.new("TextButton")
    hitArea.Size               = UDim2.fromScale(1,1)
    hitArea.Position           = UDim2.fromOffset(0,-14)
    hitArea.BackgroundTransparency = 1
    hitArea.Text               = ""
    hitArea.ZIndex             = 5
    hitArea.Parent             = track

    hitArea.MouseButton1Down:Connect(function(x,_)
        dragging = true
        updateSlider(x)
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

