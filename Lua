-- ‚ĒÄ‚ĒÄ CAMERA LOCK (aim assist) ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local Camera = workspace.CurrentCamera

local function getNearestEnemy()
    local chr   = LP.Character
    local hrp   = chr and chr:FindFirstChild("HumanoidRootPart")
    if not hrp  then return nil end
    local cam   = Camera
    local vp    = cam.ViewportSize
    local center = Vector2.new(vp.X/2, vp.Y/2)
    local best, bestDist = nil, math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP then
            local pChr = p.Character
            local head = pChr and pChr:FindFirstChild("Head")
            local phum = pChr and pChr:FindFirstChildOfClass("Humanoid")
            if head and phum and phum.Health > 0 then
                local screenPos, onScreen = cam:WorldToScreenPoint(head.Position)
                if onScreen then
                    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
                    if dist < State.AimFOV and dist < bestDist then
                        bestDist = dist
                        best     = p
                    end
                end
            end
        end
    end
    return best
end

local function startCameraLock()
    State.camLockConn = RunService.RenderStepped:Connect(function()
        safePcall(function()
            local target = getNearestEnemy()
            if not target then return end
            local head = target.Character and target.Character:FindFirstChild("Head")
            if head then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, head.Position)
            end
        end)
    end)
end

local function stopCameraLock()
    if State.camLockConn then State.camLockConn:Disconnect() State.camLockConn = nil end
end

-- ‚ĒÄ‚ĒÄ AUTO SHOOT ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local function startAutoShoot()
    State.autoShootConn = RunService.Heartbeat:Connect(function()
        safePcall(function()
            local chr  = LP.Character
            local tool = chr and chr:FindFirstChildOfClass("Tool")
            if not tool then return end
            -- only fire if we have a camera-locked target
            if not State.CameraLock then return end
            local target = getNearestEnemy()
            if not target then return end
            -- fire every shoot remote in the tool
            for _, v in ipairs(tool:GetDescendants()) do
                if v:IsA("RemoteEvent") then
                    local n = v.Name:lower()
                    if n:find("shoot") or n:find("fire") or n:find("attack") then
                        safePcall(function() v:FireServer() end)
                    end
                end
            end
            tool:Activate()
        end)
    end)
end

local function stopAutoShoot()
