--  HOOKFUNCTION ON MODULE FUNCTIONS
-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local function hookModuleFunction(tbl, key, replacement)
    if not tbl or type(tbl[key]) ~= "function" then return false end
    local ok, err = pcall(function()
        State.hookedFunctions[key] = hookfunction(tbl[key], replacement)
    end)
    if ok then
        print("[exploit] hooked " .. key)
        return true
    end
    warn("[exploit] hookfunction failed on " .. key .. ": " .. tostring(err))
    return false
end

-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
--  METATABLE HOOK  (namecall spy + modifier)
-- ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
local mt       = getrawmetatable(game)
local oldNC    = mt.__namecall
local oldIndex = mt.__index
setreadonly(mt, false)

-- Remote spy ‚ÄĒ logs all FireServer/InvokeServer calls
-- so we can learn the game's remote schema
local remoteLog = {}

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    local args   = {...}

    -- ‚ĒÄ‚ĒÄ Remote spy ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if method == "FireServer" or method == "InvokeServer" then
        local path = self:GetFullName()
        if not remoteLog[path] then
            remoteLog[path] = true
            print(string.format("[SPY] %s::%s(%s)",
                path, method,
                table.concat(
                    (function()
                        local s = {}
                        for _, a in ipairs(args) do
                            table.insert(s, tostring(a))
                        end
                        return s
                    end)(),
                    ", "
                )
            ))
        end
    end

    -- ‚ĒÄ‚ĒÄ God mode: block damage remotes ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if State.GodMode and method == "FireServer" then
        local n = self.Name:lower()
        if n:find("damage") or n:find("hurt") or n:find("kill")
           or n:find("health") or n:find("hit") then
            return  -- silently drop
        end
    end

    -- ‚ĒÄ‚ĒÄ Infinite ammo: intercept reload remotes ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
    if State.InfiniteAmmo and method == "FireServer" then
        local n = self.Name:lower()
        if n:find("reload") or n:find("ammo") or n:find("magazine") then
            return  -- block server reload validation
        end
    end

    return oldNC(self, ...)
end)

-- ‚ĒÄ‚ĒÄ __index hook ‚ÄĒ lie to AC about WalkSpeed / Health ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
mt.__index = newcclosure(function(self, key)
    if State.AntiAC then
        local lpChar = LP.Character
        if lpChar then
            local hum = lpChar:FindFirstChildOfClass("Humanoid")
            if hum then
                if self == hum then
                    if key == "WalkSpeed"  then return 16  end  -- lie: show normal speed
                    if key == "JumpPower"  then return 50  end
                end
                if self == lpChar:FindFirstChild("HumanoidRootPart") then
                    if key == "Position" then
                        -- return last safe position if we are in void
                        return oldIndex(self, key)
                    end
                end
            end
        end
    end
    return oldIndex(self, key)
end)

setreadonly(mt, true)

