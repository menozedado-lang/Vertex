--  Games use Attribute modules to read/set instance attributes
--  We hook it to intercept attribute reads/writes
local function exploitAttribute()
    if not UtilAttribute then return end
    safePcall(function()
        dumpModule("Util.Attribute", UtilAttribute)

        -- hook Set to intercept health / damage attribute writes
        hookModuleFunction(UtilAttribute, "Set", function(instance, key, value)
            local kl = tostring(key):lower()
            if State.GodMode then
                if kl == "health" then value = 999999 end
                if kl == "damage" and instance ~= LP.Character then
                    -- block damage sets on our own character
                    if instance == LP.Character then return end
                end
            end
            if State.InfiniteAmmo then
                if kl == "ammo" or kl == "magazine" then value = 9999 end
                if kl == "reloadtime" or kl == "cooldown" then value = 0 end
            end
            return State.hookedFunctions["Set"](instance, key, value)
        end)

        -- hook Get to lie about health to AC
        hookModuleFunction(UtilAttribute, "Get", function(instance, key)
            local kl   = tostring(key):lower()
            local orig = State.hookedFunctions["Get"]
            if State.AntiAC and instance == LP.Character then
                if kl == "walkspeed" then return 16   end
                if kl == "health"    then return 100  end
            end
            return orig(instance, key)
        end)
    end)
end

